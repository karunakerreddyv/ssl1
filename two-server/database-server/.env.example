# =============================================================================
# PRAVAHA PLATFORM - DATABASE SERVER CONFIGURATION
# =============================================================================
#
# Architecture:
#   Database Server (this):  Native PostgreSQL 17 + Optional Redis
#   App Server (remote):     Docker services (backend, ML, Superset, etc.)
#
# This server runs native PostgreSQL (not Docker) with optional monitoring agents.
# Use the scripts/ directory for PostgreSQL installation and configuration.
#
# Quick Start:
#   1. Copy this file: cp .env.example .env
#   2. Set APP_SERVER_IP for log aggregation
#   3. Install PostgreSQL: sudo ./scripts/install-postgres.sh
#   4. Start log agent: docker compose -f docker-compose.logging.yml up -d
#
# =============================================================================

# =============================================================================
# SECTION 1: NETWORK CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# 1.1 App Server Connection (REQUIRED for log aggregation)
# IP address or hostname of the App Server running Loki
# -----------------------------------------------------------------------------
APP_SERVER_IP=192.168.1.10

# =============================================================================
# SECTION 2: POSTGRESQL CONFIGURATION (Native Installation)
# =============================================================================
# These are used by install scripts and postgres_exporter
# The actual PostgreSQL runs as a native service, not Docker

# -----------------------------------------------------------------------------
# 2.1 PostgreSQL Credentials
# Must match what you configure during PostgreSQL installation
# -----------------------------------------------------------------------------
POSTGRES_USER=pravaha
# Generate password: openssl rand -base64 16 | tr -d '\n/+='
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database names created during installation
PLATFORM_DB=autoanalytics
SUPERSET_DB=superset
# Analytics database — holds use case source/output data (seed_data schema)
# Set to 'analytics_db' to separate use case data from platform metadata.
# Leave empty or set to same as PLATFORM_DB to keep everything in one database.
# Auto-created by init-databases.sql on first PostgreSQL start.
ANALYTICS_DB=analytics_db

# -----------------------------------------------------------------------------
# 2.2 PostgreSQL Log Directory
# Default PostgreSQL log location (varies by installation method)
# Ubuntu/Debian apt: /var/log/postgresql/
# Data directory logs: /var/lib/postgresql/<version>/main/log/
# -----------------------------------------------------------------------------
POSTGRES_LOG_DIR=/var/lib/postgresql/17/main/log

# =============================================================================
# SECTION 3: LOGGING AGENT (Promtail → App Server Loki)
# =============================================================================
# Promtail collects PostgreSQL logs and sends to App Server's Loki

# -----------------------------------------------------------------------------
# 3.1 Remote Loki Configuration
# Promtail pushes logs to App Server's Loki instance
# -----------------------------------------------------------------------------
LOKI_URL=http://${APP_SERVER_IP}:3100

# Environment identifier for log labels
NODE_ENV=production

# =============================================================================
# SECTION 4: MONITORING (Optional - postgres_exporter)
# =============================================================================
# The postgres_exporter exposes metrics for Prometheus scraping

# -----------------------------------------------------------------------------
# 4.1 PostgreSQL Exporter Connection String
# Used by postgres_exporter to connect to local PostgreSQL
# Format: postgresql://user:password@host:port/database?sslmode=disable
# -----------------------------------------------------------------------------
DATA_SOURCE_NAME=postgresql://pravaha:CHANGE_ME_SECURE_PASSWORD@localhost:5432/postgres?sslmode=disable

# Exporter port (Prometheus scrapes this endpoint)
POSTGRES_EXPORTER_PORT=9187

# =============================================================================
# SECTION 5: SSL/TLS CONFIGURATION (Optional)
# =============================================================================
# Configure if using SSL for PostgreSQL connections

# -----------------------------------------------------------------------------
# 5.1 SSL Enable/Disable
# -----------------------------------------------------------------------------
# IMPORTANT: Set to any non-empty value (e.g., "true") to enable SSL.
# Leave empty to disable SSL. Do NOT use "false" (non-empty = enabled).
POSTGRES_SSL_ENABLED=
POSTGRES_SSL_MODE=prefer

# SSL Certificate paths (for client certificate authentication)
# These are generated by ./scripts/setup-ssl.sh
POSTGRES_SSL_CA=/etc/postgresql/17/main/ssl/ca.crt
POSTGRES_SSL_CERT=/etc/postgresql/17/main/ssl/server.crt
POSTGRES_SSL_KEY=/etc/postgresql/17/main/ssl/server.key

# =============================================================================
# SECTION 6: BACKUP CONFIGURATION (Optional)
# =============================================================================
# Settings for automated backup scripts

# -----------------------------------------------------------------------------
# 6.1 Backup Destinations
# -----------------------------------------------------------------------------
BACKUP_DIR=/opt/pravaha/backups/postgres
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESSION=gzip

# S3-compatible backup storage (optional)
BACKUP_S3_ENABLED=false
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=pravaha/database-backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# =============================================================================
# SECTION 7: ALERTING THRESHOLDS (Optional)
# =============================================================================
# Thresholds used by health-check.sh and monitoring alerts

# -----------------------------------------------------------------------------
# 7.1 Connection Thresholds
# -----------------------------------------------------------------------------
MAX_CONNECTIONS_WARNING=80
MAX_CONNECTIONS_CRITICAL=95

# -----------------------------------------------------------------------------
# 7.2 Disk Space Thresholds (percentage)
# -----------------------------------------------------------------------------
DISK_WARNING_PERCENT=80
DISK_CRITICAL_PERCENT=90

# -----------------------------------------------------------------------------
# 7.3 Query Thresholds
# -----------------------------------------------------------------------------
SLOW_QUERY_THRESHOLD_MS=1000
LONG_RUNNING_QUERY_THRESHOLD_SECONDS=300

# =============================================================================
# SECTION 8: ELK STACK (Optional - Alternative to Loki)
# =============================================================================
# Use ELK stack instead of Loki for enterprise log management

# -----------------------------------------------------------------------------
# 8.1 Elasticsearch Configuration
# -----------------------------------------------------------------------------
ELASTICSEARCH_HOSTS=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTIC_PASSWORD=CHANGE_ME_ELASTIC_PASSWORD
ELASTICSEARCH_INDEX=pravaha-postgres-logs

# =============================================================================
# NOTES
# =============================================================================
#
# PostgreSQL Installation:
#   The database server runs native PostgreSQL, not Docker.
#   Use ./scripts/install-postgres.sh for one-command installation.
#   See README.md for manual installation instructions.
#
# Log Aggregation:
#   Promtail runs in Docker and collects PostgreSQL logs.
#   Logs are pushed to App Server's Loki (port 3100).
#   Ensure APP_SERVER_IP is correctly set.
#
# Metrics Collection:
#   Install postgres_exporter for Prometheus metrics:
#   ./scripts/install-postgres-exporter.sh
#   App Server's Prometheus scrapes this server on port 9187.
#
# Firewall Rules:
#   - Allow PostgreSQL (5432) from App Server IP
#   - Allow postgres_exporter (9187) from App Server IP (for metrics)
#   - Allow SSH (22) for administration
#
# =============================================================================
